# 数据库配置
# 【推荐】使用 docker compose 内置 PostgreSQL（已预装 pgvector，端口默认 5433 避免与本地 Postgres 冲突）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=anmei_pg_pass
POSTGRES_DB=anmeismart
POSTGRES_PORT=5433
# 本地开发（API 跑在宿主机）:
DATABASE_URL=postgresql://postgres:anmei_pg_pass@localhost:5433/anmeismart
# Docker 内 API 容器请改为:
# DATABASE_URL=postgresql://postgres:anmei_pg_pass@postgres:5432/anmeismart

# Redis配置
REDIS_URL=redis://:difyai123456@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=difyai123456
REDIS_DB=0

# JWT配置
SECRET_KEY=difyai123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 项目信息
PROJECT_NAME=AnmeiSmart
VERSION=1.0.0

# AI服务配置
AI_API_KEY=your_ai_api_key
AI_MODEL=default
AI_API_BASE_URL=https://api.example.com

# Agent / LLM 配置（OpenAI 兼容 API）
AGENT_DEFAULT_BASE_URL=https://api.openai.com/v1
AGENT_DEFAULT_MODEL=gpt-4o-mini
AGENT_DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# 启用 RAG 前请确保 pgvector 已安装，一键检查/启用:
#   cd api && source venv/bin/activate && python scripts/setup_pgvector.py

# AI Gateway配置
AI_GATEWAY_CACHE_ENABLED=true
AI_GATEWAY_CACHE_TTL=300
AI_GATEWAY_CACHE_SIZE=1000
AI_GATEWAY_CIRCUIT_BREAKER_THRESHOLD=5
AI_GATEWAY_CIRCUIT_BREAKER_TIMEOUT=60
AI_GATEWAY_DEFAULT_TIMEOUT=30
AI_GATEWAY_MAX_RETRIES=3

# 推送通知配置（暂时使用日志记录服务）
NOTIFICATION_PROVIDER=logging
# TODO: 未来集成真实推送服务时启用以下配置
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json
# APNS_CERTIFICATE_PATH=/path/to/apns-certificate.p12
# APNS_CERTIFICATE_PASSWORD=your_certificate_password
# JPUSH_APP_KEY=your_jpush_app_key
# JPUSH_MASTER_SECRET=your_jpush_master_secret
